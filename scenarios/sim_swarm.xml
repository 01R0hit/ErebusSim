<?xml version="1.0"?>
<scenario>
    <solver>
        <erp value="0.5"/>
        <cfm value="0.0"/>
    </solver>
    <environment>
        <ned latitude="41.77" longitude="3.04"/>
        <ocean>
            <waves/>
        </ocean>
        <atmosphere>
            <sun azimuth="20.0" elevation="50.0"/>
        </atmosphere>
    </environment>

    <materials>
        <material name="Neutral" density="1000.0" restitution="0.5"/>
        <material name="Rock" density="3000.0" restitution="0.8"/>
        <friction_table>
            <friction material1="Neutral" material2="Neutral" static="0.5" dynamic="0.2"/>
            <friction material1="Neutral" material2="Rock" static="0.5" dynamic="0.2"/>
            <friction material1="Rock" material2="Rock" static="0.5" dynamic="0.2"/>
        </friction_table>
    </materials>

    <looks>
        <look name="gray" gray="0.5" roughness="0.2"/>
        <look name="red" rgb="1.0 0.0 0.0" roughness="0.2"/>
        <look name="yellow" rgb="1.0 1.0 0.0" roughness="0.2"/>
        <look name="green" rgb="0.0 1.0 0.0" roughness="0.2"/>
    </looks>

    <static name="Seafloor" type="plane">
        <material name="Rock"/>
        <look name="gray"/>
        <world_transform xyz="0.0 0.0 200.0" rpy="0.0 0.0 0.0"/>
    </static>

    <robot name="Surface_Base" fixed="true" self_collisions="false">
        <origin xyz="0.0 0.0 1.0" rpy="0.0 0.0 0.0"/>
        <base_link name="Vehicle" type="box" physics="submerged">
            <dimensions l="1.0" w="1.0" h="1.0"/>
            <material name="Neutral"/>
            <look name="red"/>
            <mass value="50.0"/>
            <cg xyz="0.0 0.0 0.0"/>
        </base_link>
        <sensors>
            <sensor name="odom" type="odometry" rate="10.0">
                <link name="Vehicle"/>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <ros_publisher topic="/stonefish/surface_base/pose"/>
            </sensor>
        </sensors>
    </robot>

    <robot name="AUV_1" fixed="false" self_collisions="false">
        <origin xyz="10.0 0.0 5.0" rpy="0.0 0.0 0.0"/>
        <base_link name="Vehicle" type="cylinder" physics="submerged">
            <dimensions radius="0.15" length="1.5"/>
            <material name="Neutral"/>
            <look name="yellow"/>
            <mass value="30.0"/>
            <cg xyz="0.0 0.0 0.0"/>
        </base_link>
        
        <actuators>
            <actuator name="Thruster0" type="thruster">
                <link name="Vehicle"/>
                <origin xyz="-0.75 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <propeller diameter="0.08" right="true">
                    <mesh filename="$(find sim_swarm)/data/meshes/dummy_prop.obj" scale="0.5"/>
                    <material name="Neutral"/>
                    <look name="gray"/>
                </propeller>
                <specs max_setpoint="3000.0"/>
                <rotor_dynamics type="zero_order"/>
                <thrust_model type="quadratic">
                    <rotor_constant value="0.4472"/>
                </thrust_model>
                <ros_subscriber topic="/stonefish/auv_1/thruster_0"/>
            </actuator>
        </actuators>

        <sensors>
            <sensor name="odom" type="odometry" rate="10.0">
                <link name="Vehicle"/>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <ros_publisher topic="/stonefish/auv_1/pose"/>
            </sensor>
        </sensors>
    </robot>

    <robot name="AUV_2" fixed="false" self_collisions="false">
        <origin xyz="5.0 0.0 2.5" rpy="0.0 0.0 0.0"/>
        <base_link name="Vehicle" type="cylinder" physics="submerged">
            <dimensions radius="0.15" length="1.5"/>
            <material name="Neutral"/>
            <look name="green"/>
            <mass value="30.0"/>
            <cg xyz="0.0 0.0 0.0"/>
        </base_link>

        <actuators>
            <actuator name="Thruster0" type="thruster">
                <link name="Vehicle"/>
                <origin xyz="-0.75 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <propeller diameter="0.08" right="true">
                    <mesh filename="$(find sim_swarm)/data/meshes/dummy_prop.obj" scale="0.5"/>
                    <material name="Neutral"/>
                    <look name="gray"/>
                </propeller>
                <specs max_setpoint="3000.0"/>
                <rotor_dynamics type="zero_order"/>
                <thrust_model type="quadratic">
                    <rotor_constant value="0.4472"/>
                </thrust_model>
                <ros_subscriber topic="/stonefish/auv_2/thruster_0"/>
            </actuator>
        </actuators>

        <sensors>
            <sensor name="odom" type="odometry" rate="10.0">
                <link name="Vehicle"/>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <ros_publisher topic="/stonefish/auv_2/pose"/>
            </sensor>
        </sensors>
    </robot>
</scenario>