<?xml version="1.0"?>
<scenario>
    <solver>
        <erp value="0.5"/>
        <cfm value="0.0"/>
    </solver>

    <environment>
        <ned latitude="18.5204" longitude="73.8567"/>
        <ocean>
            <water density="1028.0" jerlov="3"/>
            <waves height="0.0"/>
        </ocean>
        <atmosphere>
            <sun azimuth="50.0" elevation="50.0"/>
        </atmosphere>
    </environment>

    <materials>
        <material name="Neutral" density="784.0" restitution="0.5"/>
        <material name="Lead" density="10000.0" restitution="0.1"/>
        <material name="Rock" density="3000.0" restitution="0.8"/>
        <friction_table>
            <friction material1="Neutral" material2="Neutral" static="0.5" dynamic="0.2"/>
            <friction material1="Neutral" material2="Rock" static="0.5" dynamic="0.2"/>
            <friction material1="Rock" material2="Rock" static="0.5" dynamic="0.2"/>
        </friction_table>
    </materials>

    <looks>
        <look name="hull_color" gray="0.6" roughness="0.3"/>
        <look name="wall_color" gray="0.3" roughness="0.9"/>
        <look name="gray" gray="0.5" roughness="0.2"/>
        <look name="red" rgb="1.0 0.0 0.0" roughness="0.2"/>
    </looks>

    <static name="Seafloor" type="plane">
        <material name="Rock"/>
        <look name="gray"/>
        <world_transform xyz="0.0 0.0 200.0" rpy="0.0 0.0 0.0"/>
    </static>

    <robot name="Surface_Base" fixed="true" self_collisions="false">
        <base_link name="Vehicle" type="box" physics="submerged">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <dimensions xyz="1.0 1.0 1.0"/>
            <material name="Neutral"/>
            <look name="red"/>
            <mass value="50.0"/>
            <cg xyz="0.0 0.0 0.0"/>
        </base_link>
        
        <sensors>
            <sensor name="odom" type="odometry" rate="10.0">
                <link name="Vehicle"/>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <ros_publisher topic="/stonefish/surface_base/pose"/>
            </sensor>
        </sensors>
        
        <world_transform xyz="0.0 0.0 1.0" rpy="0.0 0.0 0.0"/>
    </robot>

    <robot name="scanner_1" fixed="false" self_collisions="false">
        
        <base_link name="hull" type="cylinder" physics="submerged">
            <dimensions radius="0.15" height="1.5"/>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <material name="Neutral"/>
            <look name="hull_color"/>
        </base_link>

        <link name="internal_ballast" type="box" physics="submerged">
            <dimensions xyz="0.05 0.05 1.0"/>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <material name="Lead"/>
            <look name="hull_color"/>
        </link>

        <joint name="ballast_joint" type="fixed">
            <parent name="hull"/>
            <child name="internal_ballast"/>
            <origin xyz="-0.10 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </joint>
        
        <actuator name="thruster_port" type="thruster">
            <specs max_setpoint="1.0" inverted_setpoint="false" normalized_setpoint="true"/>
            <propeller diameter="0.1" right="true">
                <mesh filename="$(find sim_swarm)/data/meshes/dummy_prop.obj" scale="1.0"/>
                <material name="Neutral"/>
                <look name="hull_color"/>
            </propeller>
            <rotor_dynamics type="first_order">
                <time_constant value="0.1"/>
            </rotor_dynamics>
            <thrust_model type="quadratic">
                <thrust_coeff value="100.0"/>
                <torque_coeff value="5.0"/>
            </thrust_model>
            
            <origin xyz="0.0 -0.2 -0.75" rpy="0.0 -1.5708 0.0"/>
            <link name="hull"/>
            <ros_subscriber topic="/scanner_1/thrusters/port/command"/>
        </actuator>

        <actuator name="thruster_starboard" type="thruster">
            <specs max_setpoint="1.0" inverted_setpoint="false" normalized_setpoint="true"/>
            <propeller diameter="0.1" right="false">
                <mesh filename="$(find sim_swarm)/data/meshes/dummy_prop.obj" scale="1.0"/>
                <material name="Neutral"/>
                <look name="hull_color"/>
            </propeller>
            <rotor_dynamics type="first_order">
                <time_constant value="0.1"/>
            </rotor_dynamics>
            <thrust_model type="quadratic">
                <thrust_coeff value="100.0"/>
                <torque_coeff value="5.0"/>
            </thrust_model>
            <origin xyz="0.0 0.2 -0.75" rpy="0.0 -1.5708 0.0"/>
            <link name="hull"/>
            <ros_subscriber topic="/scanner_1/thrusters/starboard/command"/>
            
        </actuator>

        <actuator name="vbs_system" type="vbs">
            <volume initial="0.5">
                <mesh filename="$(find sim_swarm)/data/meshes/empty.obj"/>
                <mesh filename="$(find sim_swarm)/data/meshes/half.obj"/>
                <mesh filename="$(find sim_swarm)/data/meshes/full.obj"/>
            </volume>
            <origin xyz="0.0 0.6 0.0" rpy="0.0 0.0 0.0"/>
            <link name="hull"/>
            <ros_publisher topic="/scanner_1/vbs_system/state"/>
            <ros_subscriber topic="/scanner_1/vbs_system/command"/>
        </actuator>
    
		<light name="headlight">
		    <specs radius="0.05" cone_angle="45.0" illuminance="100000.0"/>
		    <color temperature="5600.0"/>
		    <origin xyz="0.0 0.0 0.76" rpy="0.0 0.0 0.0"/>
		    <link name="hull"/>
		</light>

        <sensor name="sss_port" rate="5.0" type="sss">
            <specs bins="500" lines="400" horizontal_beam_width="2.0" vertical_beam_width="50.0" vertical_tilt="60.0"/>
            <settings range_min="1.0" range_max="40.0" gain="1.2"/>
            <noise multiplicative="0.02" additive="0.04"/>
            <display colormap="hot"/>
            <origin xyz="0.0 -0.16 0.0" rpy="0.0 0.0 -1.5708"/>
            <link name="hull"/>
            <ros_publisher topic="/scanner_1/sss_port"/>
        </sensor>

        <sensor name="sss_starboard" rate="5.0" type="sss">
            <specs bins="500" lines="400" horizontal_beam_width="2.0" vertical_beam_width="50.0" vertical_tilt="60.0"/>
            <settings range_min="1.0" range_max="40.0" gain="1.2"/>
            <noise multiplicative="0.02" additive="0.04"/>
            <display colormap="hot"/>
            <origin xyz="0.0 0.16 0.0" rpy="0.0 0.0 1.5708"/>
            <link name="hull"/>
            <ros_publisher topic="/scanner_1/sss_starboard"/>
        </sensor>

        <sensor name="front_camera" type="camera" rate="30.0">
    		<specs resolution_x="800" resolution_y="600" horizontal_fov="90.0"/>
			<origin xyz="0.2 0.0 0.0" rpy="0.0 0.0 0.0"/>
			<link name="hull"/>
			<ros_publisher topic="/scanner_1/front_camera/image"/>
		</sensor>

        <sensor name="odom" type="odometry" rate="30.0">
            <noise position="0.01" velocity="0.01" angle="0.01" angular_velocity="0.01"/>
            <history samples="1"/>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <link name="hull"/>
            <ros_publisher topic="/scanner_1/odom"/>
        </sensor>


        <ros_subscriber topic="/scanner_1/thruster_setpoints"/>
        <world_transform xyz="0.0 -3.0 5.0" rpy="0.0 1.5708 0.0"/>
        
    </robot>

    <robot name="scanner_2" fixed="false" self_collisions="false">
        
        <base_link name="hull" type="cylinder" physics="submerged">
            <dimensions radius="0.15" height="1.5"/>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <material name="Neutral"/>
            <look name="hull_color"/>
        </base_link>

        <link name="internal_ballast" type="box" physics="submerged">
            <dimensions xyz="0.05 0.05 1.0"/>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <material name="Lead"/>
            <look name="hull_color"/>
        </link>

        <joint name="ballast_joint" type="fixed">
            <parent name="hull"/>
            <child name="internal_ballast"/>
            <origin xyz="-0.10 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </joint>

        <actuator name="thruster_port" type="thruster">
            <specs max_setpoint="1.0" inverted_setpoint="false" normalized_setpoint="true"/>
            <propeller diameter="0.1" right="true">
                <mesh filename="$(find sim_swarm)/data/meshes/dummy_prop.obj" scale="1.0"/>
                <material name="Neutral"/>
                <look name="hull_color"/>
            </propeller>
            <rotor_dynamics type="first_order">
                <time_constant value="0.1"/>
            </rotor_dynamics>
            <thrust_model type="quadratic">
                <thrust_coeff value="100.0"/>
                <torque_coeff value="5.0"/>
            </thrust_model>
            <origin xyz="0.0 -0.2 -0.75" rpy="0.0 -1.5708 0.0"/>
            <link name="hull"/>
            <ros_subscriber topic="/scanner_2/thrusters/port/command"/>
        </actuator>

        <actuator name="thruster_starboard" type="thruster">
            <specs max_setpoint="1.0" inverted_setpoint="false" normalized_setpoint="true"/>
            <propeller diameter="0.1" right="false">
                <mesh filename="$(find sim_swarm)/data/meshes/dummy_prop.obj" scale="1.0"/>
                <material name="Neutral"/>
                <look name="hull_color"/>
            </propeller>
            <rotor_dynamics type="first_order">
                <time_constant value="0.1"/>
            </rotor_dynamics>
            <thrust_model type="quadratic">
                <thrust_coeff value="100.0"/>
                <torque_coeff value="5.0"/>
            </thrust_model>
            <origin xyz="0.0 0.2 -0.75" rpy="0.0 -1.5708 0.0"/>
            <link name="hull"/>
            <ros_subscriber topic="/scanner_2/thrusters/starboard/command"/>
            
        </actuator>

        <actuator name="vbs_system" type="vbs">
            <volume initial="0.5">
                <mesh filename="$(find sim_swarm)/data/meshes/empty.obj"/>
                <mesh filename="$(find sim_swarm)/data/meshes/half.obj"/>
                <mesh filename="$(find sim_swarm)/data/meshes/full.obj"/>
            </volume>
            <origin xyz="0.0 0.6 0.0" rpy="0.0 0.0 0.0"/>
            <link name="hull"/>
            <ros_publisher topic="/scanner_2/vbs_system/state"/>
            <ros_subscriber topic="/scanner_2/vbs_system/command"/>
        </actuator>
        
        <light name="headlight">
            <specs radius="0.05" cone_angle="45.0" illuminance="100000.0"/>
            <color temperature="5600.0"/>
            <origin xyz="0.0 0.0 0.76" rpy="0.0 0.0 0.0"/>
            <link name="hull"/>
        </light>


        <sensor name="sss_port" rate="5.0" type="sss">
            <specs bins="500" lines="400" horizontal_beam_width="2.0" vertical_beam_width="50.0" vertical_tilt="60.0"/>
            <settings range_min="1.0" range_max="40.0" gain="1.2"/>
            <noise multiplicative="0.02" additive="0.04"/>
            <display colormap="hot"/>
            <origin xyz="0.0 -0.16 0.0" rpy="0.0 0.0 -1.5708"/>
            <link name="hull"/>
            <ros_publisher topic="/scanner_2/sss_port"/>
        </sensor>

        <sensor name="sss_starboard" rate="5.0" type="sss">
            <specs bins="500" lines="400" horizontal_beam_width="2.0" vertical_beam_width="50.0" vertical_tilt="60.0"/>
            <settings range_min="1.0" range_max="40.0" gain="1.2"/>
            <noise multiplicative="0.02" additive="0.04"/>
            <display colormap="hot"/>
            <origin xyz="0.0 0.16 0.0" rpy="0.0 0.0 1.5708"/>
            <link name="hull"/>
            <ros_publisher topic="/scanner_2/sss_starboard"/>
        </sensor>
        
        <sensor name="front_camera" type="camera" rate="30.0">
    		<specs resolution_x="800" resolution_y="600" horizontal_fov="90.0"/>
			<origin xyz="0.2 0.0 0.0" rpy="0.0 0.0 0.0"/>
			<link name="hull"/>
			<ros_publisher topic="/scanner_2/front_camera/image"/>
		</sensor>

        <sensor name="odom" type="odometry" rate="30.0">
            <noise position="0.01" velocity="0.01" angle="0.01" angular_velocity="0.01"/>
            <history samples="1"/>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <link name="hull"/>
            <ros_publisher topic="/scanner_2/odom"/>
        </sensor>

        <ros_subscriber topic="/scanner_2/thruster_setpoints"/>
        <world_transform xyz="0.0 3.0 5.0" rpy="0.0 1.5708 0.0"/>
        
    </robot>
</scenario>